{
  "name": "@cryptobenkei/c4e",
  "version": "0.4.0",
  "description": "c4e agent-template catalog — the Members manager and per-member agent for the c4e community. Each member has their own dedicated agent, reached primarily through the c4e Telegram bot. Ships the `join-community` invite flow and the `user-interview` self-onboarding workflow.",
  "keywords": [
    "benkei",
    "ai",
    "agents",
    "templates",
    "c4e",
    "community",
    "members"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benkei-ai/c4e.git"
  },
  "homepage": "https://github.com/benkei-ai/c4e#readme",
  "bugs": "https://github.com/benkei-ai/c4e/issues",
  "author": "benkei-ai",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./src/ui/index.ts"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js",
      "require": "./dist/actions.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "src/ui"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "viz": "node ../benkei-agent-core/packages/cli/dist/cli.js admin --template ./dist/index.js --open"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@benkei-ai/core": "^0.3.0"
  },
  "devDependencies": {
    "@benkei-ai/core": "link:../benkei-agent-core/packages/core",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^0.460.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "ISC"
}
